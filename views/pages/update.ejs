<% layout("./layouts/stuff.ejs"); %>

<div class="container mt-4">
  <div class="row">
    <div class="col-8 offset-2">
      <h2 class="mb-4">Update Place Info</h2>

      <!-- Update form -->
      <form method="POST" action="/jiitscout/stuff/<%= building._id %>?_method=PUT" class="needs-validation" novalidate>
        
        <div class="mb-3">
          <label for="name" class="form-label">Place Name</label>
          <input type="text" class="form-control" id="name" name="building[name]" value="<%= building.name %>" required>
          <div class="invalid-feedback">Please enter the building name.</div>
        </div>

        <div class="mb-3">
          <label for="desc" class="form-label">Description</label>
          <textarea class="form-control" id="desc" name="building[desc]" rows="3" required><%= building.desc %></textarea>
          <div class="invalid-feedback">Please enter a description.</div>
        </div>

        <div class="mb-3">
          <label for="type" class="form-label">Type</label>
          <input type="text" class="form-control" id="type" name="building[type]" value="<%= building.type %>">
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Image URL</label>
          <input type="text" class="form-control" id="image" name="building[image][url]" value="<%= building.image.url %>">
        </div>

        <button type="submit" class="btn search-btn">Update</button>
        <a href="/jiitscout/stuff/<%= building._id %>" class="btn btn-secondary ms-2">Cancel</a>
      </form>
    </div>
  </div>
</div>

<script>
  // Bootstrap form validation
  (function () {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.prototype.slice.call(forms).forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      }, false);
    });
  })();
</script>