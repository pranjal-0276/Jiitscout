<% layout("./layouts/stuff.ejs"); %>

<div class="row">

<% for(let building of buildings){ %>

  <div class="col-12 col-md-6 col-lg-4 mb-4 card-wrapper"> <!-- ✅ RESPONSIVE -->
<a href="/jiitscout/stuff/<%= building._id %>" style="text-decoration: none; color: inherit;">
    <div class="card h-100"> <!-- ✅ IMPORTANT -->

      <img src="<%= building.image.url %>" class="card-img-top" alt="image" />

      <div class="card-body">
        <h5 class="card-title"><%= building.name %></h5>
        <p class="card-text"><%= building.desc %></p>
      </div>

    </div>
  </a>

  </div>

<% } %>

</div>